set_property IOSTANDARD LVCMOS33 [get_ports servo_sig]
set_property PACKAGE_PIN T6 [get_ports servo_sig]
set_property PACKAGE_PIN J2 [get_ports rst]
set_property -dict {PACKAGE_PIN V5 IOSTANDARD LVCMOS33} [get_ports RGB1];   
